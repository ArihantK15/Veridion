DATABASE_URL=postgresql://aletheore:changeme@postgres:5432/aletheore_app
POSTGRES_PASSWORD=changeme
REDIS_URL=redis://redis:6379/0
GITHUB_APP_ID=

# The App's private key is a multi-line PEM, which plain env-file values
# cannot hold (docker run/compose --env-file rejects newlines outright -
# confirmed empirically, not assumed). Place the downloaded .pem file at
# github-app/app-private-key.pem (docker-compose.yml mounts it and sets
# GITHUB_APP_PRIVATE_KEY_PATH for you) - GITHUB_APP_PRIVATE_KEY below is
# only a fallback for setups that inject a real env var directly.
GITHUB_APP_PRIVATE_KEY=

GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=
PUBLIC_BASE_URL=https://aletheore.com
ANTHROPIC_API_KEY=

# Optional paid-tier endpoint health monitoring config is stored per
# installation through the admin API. No global base URL or latency threshold is
# read from this file.
